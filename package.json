{
  "name": "@el-gabo-45/weigong",
  "version": "2.0.1",
  "private": false,
  "type": "module",
  "description": "13×13 variant chess game – full browser package (engine + UI + tools)",
  "main": "src/main.js",
  "workspaces": [
    "engine"
  ],
  "scripts": {
    "start": "tsx --import tsx --max-old-space-size=8192 --expose-gc engine/server/server.js",
    "dev": "DEBUG=server,nn,selfplay tsx --import tsx engine/server/server.js",
    "dev:ai": "DEBUG=ai,search,memory,perf tsx --import tsx engine/server/server.js",
    "dev:all": "DEBUG=all tsx --import tsx engine/server/server.js",
    "debug": "tsx engine/debug/debug-cli.js",
    "debug:eval": "tsx engine/debug/debug-cli.js eval",
    "debug:search": "tsx engine/debug/debug-cli.js search 5 2000",
    "debug:memory": "tsx engine/debug/debug-cli.js memory stats",
    "debug:top": "tsx engine/debug/debug-cli.js memory top 15",
    "debug:blunders": "tsx engine/debug/debug-cli.js memory blunders 10",
    "debug:nn": "tsx engine/debug/debug-cli.js nn info",
    "debug:nn:predict": "tsx engine/debug/debug-cli.js nn predict",
    "debug:games": "tsx engine/debug/debug-cli.js games",
    "debug:perft": "tsx engine/debug/debug-cli.js perft 3",
    "debug:selfplay": "tsx engine/debug/debug-cli.js selfplay 1",
    "debug:tt": "tsx engine/debug/debug-cli.js tt 6",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --verbose",
    "test:engine": "node --experimental-vm-modules node_modules/.bin/jest tests/board.test.js tests/check.test.js tests/core.test.js tests/moves.test.js tests/utils.test.js tests/hashing.test.js tests/evaluation.test.js --verbose",
    "lint": "eslint src/ tests/ engine/",
    "build": "node scripts/build-ai-js.cjs && npx tsc -p tsconfig.build.json 2>/dev/null && cp -r dist-build/* . 2>/dev/null || true",
    "format": "prettier --write ."
  },
  "files": [
    "index.html",
    "styles.css",
    "src/",
    "engine/",
    "docs/"
  ],
  "keywords": [
    "chess",
    "variant",
    "13x13",
    "gpu",
    "neural-network",
    "ai",
    "opencl"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@el-gabo-45/weigong-engine": "*",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/El-Gabo-45/Weigong.git"
  }
}
